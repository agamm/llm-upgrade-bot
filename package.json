{
  "name": "llm-upgrade-bot",
  "version": "0.1.0",
  "description": "Dependabot for LLM model versions — scans codebases for outdated model strings and proposes upgrades",
  "type": "module",
  "bin": {
    "llm-upgrade-bot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-variants.ts",
    "discover": "tsx scripts/discover-models.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "model",
    "upgrade",
    "scanner",
    "dependabot",
    "github-action"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "commander": "^14.0.3",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1"
  }
}